# IP Docker-хоста, доступный шлюзам SMG для Syslog и passive FTP.
PUBLIC_HOST=10.10.10.20
TZ=Asia/Novosibirsk

# Уже существующая external Docker-сеть Nginx Proxy Manager.
PROXY_NETWORK=proxy

# Сгенерируйте независимые случайные значения длиной не менее 32 символов.
POSTGRES_PASSWORD=replace-with-random-secret
CLICKHOUSE_PASSWORD=replace-with-random-secret
MINIO_ROOT_PASSWORD=replace-with-random-secret
SFTPGO_ADMIN_PASSWORD=replace-with-random-secret

# NPM завершает TLS, поэтому в production оставьте true.
SECURE_COOKIES=true

SYSLOG_PORT=514
FTP_PORT=21
